# ==========================================
# MoltStation ShellRunners (.env.example)
# ==========================================
# Copy to .env and fill values for your environment.
# Do not commit real secrets.

# ---------- Runtime ----------
NODE_ENV=development
NEXT_PUBLIC_MOLTBOT_CHAIN_ID=84532
NEXT_PUBLIC_CHAIN_ID=84532

# ---------- Core/API wiring ----------
NEXT_PUBLIC_MOLTBOT_API_URL=http://localhost:4100
NEXT_PUBLIC_CORE_LANDING_URL=http://127.0.0.1:3000
NEXT_PUBLIC_ALLOWED_PARENT_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
NEXT_PUBLIC_ALLOWED_FRAME_ANCESTORS=http://127.0.0.1:3000,http://localhost:3000
# Legacy alias still supported for backward compatibility:
NEXT_PUBLIC_CORE_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# ---------- Network / RPC ----------
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_BASE_MAINNET_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/

# ---------- Public contract addresses ----------
NEXT_PUBLIC_SHELLRUNNERS_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_MOLTBOT_MARKET_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_MOLTBOT_IDENTITY_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_MOLTBOT_REWARDS_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_MOLTBOT_POPT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_MOLTBOT_POPT_ID=
NEXT_PUBLIC_MOLTBOT_IDENTITY_ID=

# ---------- Optional helper script inputs ----------
# Used by: npm run update:addresses
# If NEXT_PUBLIC_* vars above are present, these are not required.
SHELLRUNNERS_ADDRESS=0x0000000000000000000000000000000000000000
MARKET_ADDRESS=0x0000000000000000000000000000000000000000
IDENTITY_ADDRESS=0x0000000000000000000000000000000000000000
REWARDS_ADDRESS=0x0000000000000000000000000000000000000000
POPT_ADDRESS=0x0000000000000000000000000000000000000000

# ---------- Optional Foundry deploy settings ----------
NEXT_SHELLRUNNERS_PRIVATE_KEY=0xYOUR_64_HEX_PRIVATE_KEY
NEXT_SHELLRUNNERS_DEPLOYER_ADDRESS=0x0000000000000000000000000000000000000000
SHELLRUNNERS_SIGNER_ADDRESS=0x0000000000000000000000000000000000000000
