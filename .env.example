# ==========================================
# MoltStation ShellRunners (.env.example)
# ==========================================
# Copy to .env and fill real values.
# Do not commit real secrets.

# ---------- Runtime ----------
NODE_ENV=development
CHAIN_ID=84532
MOLTBOT_CHAIN_ID=84532

# ---------- Network / RPC ----------
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_RPC_URL=https://sepolia.base.org
BASESCAN_API_KEY=

# ---------- Backend API ----------
NEXT_PUBLIC_MOLTBOT_API_URL=http://localhost:4100
MOLTBOT_API_URL=http://localhost:4100
NEXT_PUBLIC_CORE_LANDING_URL=https://moltstation.games

# ---------- Session Tuning ----------
NEXT_PUBLIC_MOLTBOT_SESSION_TTL_SECONDS=3600
NEXT_PUBLIC_MOLTBOT_SNAPSHOT_INTERVAL_MS=5000

# ---------- Storage / Metadata ----------
# Legacy local DB value (kept for compatibility; runtime tracking is now in MoltStation-Backend Mongo)
DB_URL=mongodb://127.0.0.1:27017/shellrunners
PINATA_JWT=YOUR_PINATA_JWT
NFT_STORAGE_API_KEY=
NEXT_PUBLIC_IPFS_GATEWAY=https://YOUR_GATEWAY.mypinata.cloud/ipfs/

# ---------- Public Contract Addresses ----------
NEXT_PUBLIC_SHELLRUNNERS_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_SHELLRUNNERS_MARKET_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_MOLTBOT_MARKET_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_MOLTBOT_IDENTITY_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_MOLTBOT_REWARDS_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_MOLTBOT_POPT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_MOLTBOT_POPT_ID=0
NEXT_PUBLIC_MOLTBOT_IDENTITY_ID=0

# ---------- Script / Signing Keys ----------
# Shared Safe multisig (testnet) for ownership handoff during deployment.
MOLTBOT_SAFE_MULTISIG_ADDRESS=0x5E7B07aE547C668B241cbB2a91F00EcD66cf2077
MOLTBOT_IDENTITY_ADDRESS=0x0000000000000000000000000000000000000000
SHELLRUNNERS_OWNER_ADDRESS=0x5E7B07aE547C668B241cbB2a91F00EcD66cf2077
SHELLRUNNERS_SIGNER_ADDRESS=0x0000000000000000000000000000000000000000
SHELLRUNNERS_SIGNER_PRIVATE_KEY=0xYOUR_64_HEX_PRIVATE_KEY
NEXT_SHELLRUNNERS_PRIVATE_KEY=0xYOUR_64_HEX_PRIVATE_KEY
NEXT_SHELLRUNNERS_DEPLOYER_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_SHELLRUNNERS_SIGNER_PRIVATE_KEY=0xYOUR_64_HEX_PRIVATE_KEY
MNEMONIC=

# ---------- Optional Local Seed ----------
SEED_WALLET_ADDRESS=0x0000000000000000000000000000000000000000
SEED_USERNAME=demo
SEED_NICKNAME=demo
SEED_SHELLRUNNERS_ID=ipfs://example
SEED_SHELLRUNNERS_SCORE=10
